{
	"name": "actual-whiteout-game",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@10.15.1",
	"scripts": {
		"dev": "vite --host 0.0.0.0",
		"test": "pnpm test:unit && pnpm test:assets && pnpm assets:validate",
		"test:unit": "vitest run src",
		"test:assets": "node --test tests/assets-manifest.test.mjs",
		"assets:validate": "node scripts/validate-assets.mjs",
		"typecheck": "tsc --noEmit",
		"build": "pnpm typecheck && vite build",
		"preview": "vite preview --host 0.0.0.0"
	},
	"devDependencies": {
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"vitest": "^4.1.9"
	},
	"dependencies": {
		"phaser": "^3.90.0"
	}
}
